# Environment variables for the Competitive Intelligence Agent
# Replace the placeholders with actual values

# API keys for web scraping and data retrieval

SCRAPER_API_KEY= '***********************'
NEWS_API_KEY='***************************'
LINKEDIN_API_KEY='*************************'

# Add Gemini and SerpAPI keys
GOOGLE_GEMINI_API_KEY='***************************************'
SERP_API_KEY='***************************************************'

# Database or storage configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=competitive_intel

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=competitive_intel


# Other configurations
EMAIL_NOTIFICATIONS=true
EMAIL_SENDER=your_email@example.com
EMAIL_RECIPIENT=recipient_email@example.com